<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="SandersCapstoneProject.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:SandersCapstoneProject"
    Title="SandersCapstoneProject">

    <ShellContent 
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}" />
    
    <!-- All newly added pages must go within Shell for navigation and to be linked-->
    <ShellContent 
        Title="Account Creation"
        ContentTemplate="{DataTemplate local:AccountCreation}"
        Route="AccountCreation"/>

</Shell>
